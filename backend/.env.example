# =============================================================================
# .env.example — Escoge tu Historia XR En Salud Mental
# =============================================================================
# Copia este archivo a .env y completa solo las variables que necesites.
# Con los valores por defecto (sin cambiar nada) el servidor arranca en modo
# demo: sin base de datos real, sin API de LLM — ideal para explorar el código.
#
# NUNCA pongas claves reales en este archivo. Está commiteado al repositorio.
# =============================================================================


# --- Servidor ---
PORT=7070
# HOST no se define aquí (default: 127.0.0.1 para desarrollo local).
# Si deployás en Railway/Render, configurá HOST=0.0.0.0 en la UI de la plataforma.


# =============================================================================
# BASE DE DATOS — dejar vacío activa el cliente mock (nada se persiste)
# =============================================================================
# Cuando SUPABASE_URL está vacío el servidor crea un makeNoopClient():
# todas las queries devuelven {data: null, error: null} sin crashear.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=


# =============================================================================
# LLM — "mock" no requiere API key ni conexión de red
# =============================================================================
# Opciones: mock | openrouter | cohere | groq | openai | claude | ollama
LLM_PROVIDER=mock

# Routing por rol (solo necesario cuando LLM_PROVIDER != mock):
# LLM_PROVIDER_CORE=openrouter
# LLM_PROVIDER_NARRATIVE=cohere
# LLM_PROVIDER_CORE_SECONDARY=cohere
# LLM_PROVIDER_NARRATIVE_FALLBACK=groq

# Modelos (solo necesarios cuando usás un proveedor real):
# LLM_CORE_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
# LLM_CORE_MODELS=qwen/qwen3-next-80b-a3b-instruct:free
# LLM_NARRATIVE_MODEL=command-a-03-2025
# LLM_NARRATIVE_MODEL_FALLBACK=command-a-03-2025
# LLM_NARRATIVE_MODELS=command-a-03-2025


# =============================================================================
# API KEYS (completar solo para el proveedor que vayas a usar)
# =============================================================================

# OpenRouter
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=google/gemma-3-27b-it:free
# OPENROUTER_APP_URL=
# OPENROUTER_APP_TITLE=

# Cohere
COHERE_API_KEY=
# COHERE_MODEL=command-a-03-2025

# Groq
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4-turbo

# Anthropic / Claude
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Ollama (local, sin API key)
# OLLAMA_BASE=http://localhost:11434/api


# =============================================================================
# ALEXA
# =============================================================================
# true = desactiva verificación de firma Alexa (necesario para pruebas con curl/Postman)
DISABLE_ALEXA_VERIFICATION=true
# URL que configurás en la Alexa Developer Console como endpoint del skill
BACKEND_BASE_URL=http://localhost:7070


# =============================================================================
# AUTENTICACIÓN DE ADMIN (dejar vacío = modo abierto en demo, sin token)
# =============================================================================
# Cuando cualquiera de estas está seteada, /admin/* requiere Authorization: Bearer <token>
OPERATIONS_API_KEY=
DASHBOARD_API_KEY=
# ADMIN_API_KEY=
# CLINICAL_DASHBOARD_TOKEN=


# =============================================================================
# THRESHOLDS CLÍNICOS (defaults del código, no tocar salvo calibración)
# =============================================================================
# CLINICAL_SCORE_THRESHOLD_LOW=0.30
# CLINICAL_SCORE_THRESHOLD_MODERATE=0.55
# CLINICAL_SCORE_THRESHOLD_HIGH=0.78
# PHQ9_ITEM9_MIN_SCORE=0.4
# MILD_WEIGHT_CAP=0.6
# STRONG_WEIGHT_CAP=0.9
# MAX_OPTIONS_PER_SCENE=3


# =============================================================================
# GENERACIÓN LLM — TUNING (defaults del código)
# =============================================================================
# MAX_INPUT_TOKENS=800
# MAX_OUTPUT_TOKENS=1200
# MAX_ALEXA_TEXT_CHARS=1200
# MAX_ALEXA_REPROMPT_CHARS=220
# LLM_WEEK_MAX_ATTEMPTS=2
# LLM_SCENE_TEMPERATURE=0.8
# PROMPT_VERSION=arc_scene_v2
# AUTO_CONTINUE_CHAPTER_COUNT=7


# =============================================================================
# RISK WORKER SLA (solo relevante si corrés npm run risk:worker)
# =============================================================================
# RISK_NOTIFICATION_SLA_MINUTES=15
# RISK_FIRST_ACTION_SLA_MINUTES=30
# RISK_CLOSURE_SLA_MINUTES=1440
# RISK_NOTIFICATION_WEBHOOK_URL=
